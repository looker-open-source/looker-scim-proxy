# Server
PORT=8080
PATH_TO_DB=./db.json

# SCIM bearer token auth (generate secret with: openssl rand -hex 512)
SCIM_AUTH_SECRET=

# Looker API credentials
# These map to LOOKERSDK_* automatically (same format as Cursor mcp.json)
LOOKER_BASE_URL=https://your-instance.cloud.looker.com
LOOKER_CLIENT_ID=your_api3_client_id
LOOKER_CLIENT_SECRET=your_api3_client_secret
LOOKER_VERIFY_SSL=true
